# ────────────────────────────────────────────────────────────────
# Core (required)
# ────────────────────────────────────────────────────────────────

# MongoDB connection string. Local: mongodb://127.0.0.1:27017/domdefender
# Atlas:   mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/domdefender
MONGODB_URI=mongodb://127.0.0.1:27017/domdefender

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────
# Feature flags (all optional — leave unset in dev)
# ────────────────────────────────────────────────────────────────

# Pro billing. When "true", the /pro page shows subscribe buttons and the
# shop allows USD purchases — but only if the Stripe keys below are also
# configured. When unset/false, /pro only collects waitlist emails.
# PRO_BILLING_ENABLED=false

# Stripe (only needed when PRO_BILLING_ENABLED=true).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# BYO sandbox — salt for hashing IPs in the abuse log. Rotate to reset
# rate-limit state. Defaults to a non-secret string, so set this in prod.
# BYO_IP_HASH_SALT=

# Optional comma-separated allow-list of hostnames for BYO. When set,
# ONLY these hostnames may be embedded; everything else is rejected.
# Leave unset for the normal deny-list-only policy.
# NEXT_PUBLIC_BYO_ALLOW_LIST=en.wikipedia.org,developer.mozilla.org

# Analytics webhook — if set, the client POSTs named events here.
# Unset = track() is a no-op.
# NEXT_PUBLIC_ANALYTICS_WEBHOOK_URL=https://your-sink.example.com/ingest
